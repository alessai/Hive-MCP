{
  "name": "@alessai/hive-mcp",
  "version": "1.3.0",
  "description": "MCP server that spawns external AI CLIs (Gemini, Claude, Codex) as subagents with role-based system prompts",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hive-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "conf",
    "prompts"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "cli",
    "gemini",
    "claude",
    "codex",
    "multi-agent",
    "subagent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alessai/Hive-MCP.git"
  },
  "homepage": "https://github.com/alessai/Hive-MCP",
  "bugs": {
    "url": "https://github.com/alessai/Hive-MCP/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
